# Copy to .env and adjust as needed. All values have sensible defaults in config.py.

# Ollama
OLLAMA_HOST=http://localhost:11434
AIU_MODEL_NAME=qwen3.5:9b
AIU_EMBEDDING_MODEL=nomic-embed-text
# Context window cap (small prompts; avoids a 256K-context memory blowup).
AIU_OLLAMA_NUM_CTX=8192
# HTTP timeout in seconds (covers a cold model load on the first request).
AIU_OLLAMA_TIMEOUT=180
# Keep reasoning-model "thinking" off (much faster for SQL/JSON). Set true to enable.
AIU_OLLAMA_THINK=false

# Paths (defaults are relative to the repo root)
# AIU_DATA_DIR=./data
# AIU_PARQUET_DIR=./data/parquet
# AIU_DUCKDB_PATH=./data/aiu.duckdb
# AIU_CATALOG_PATH=./data/catalog.json

# Retrieval / limits
AIU_TOP_K=5
AIU_MAX_RESULT_ROWS=5000
