# Copy to .env and adjust as needed. All values have sensible defaults in config.py.

# --- Deployment mode -------------------------------------------------------
# LOCAL=true  -> your machine: chat + embeddings via local Ollama (Fast/Smart).
# LOCAL=false -> cloud (Streamlit Cloud): chat + embeddings via OpenAI only.
LOCAL=true

# --- Ollama (local mode) ---------------------------------------------------
OLLAMA_HOST=http://localhost:11434
AIU_MODEL_NAME=qwen3.5:9b
# Two local modes in the sidebar. Override the model per mode if you like:
AIU_MODEL_FAST=qwen3.5:4b
AIU_MODEL_SMART=qwen3.5:9b
# Default mode on startup (local): fast | smart
AIU_MODEL_TIER=fast
# Per-mode context window.
AIU_FAST_NUM_CTX=16384
AIU_SMART_NUM_CTX=8192
# HTTP timeout in seconds (covers a cold model load on the first request).
AIU_OLLAMA_TIMEOUT=180
# Thinking mode is always off (prompts scaffold the reasoning; much faster).
AIU_OLLAMA_THINK=false

# --- OpenAI (cloud mode, LOCAL=false) --------------------------------------
# Needed when LOCAL=false (and optional locally). Chat + embeddings use OpenAI.
OPENAI_KEY=
# Cloud GPT modes (defaults shown):
# AIU_OPENAI_NANO=gpt-5.4-nano
# AIU_OPENAI_MINI=gpt-5.4-mini
# AIU_OPENAI_MAX=gpt-5.5

# Paths (defaults are relative to the repo root)
# AIU_DATA_DIR=./data
# AIU_PARQUET_DIR=./data/parquet
# AIU_DUCKDB_PATH=./data/aiu.duckdb
# AIU_CATALOG_PATH=./data/catalog.json

# Retrieval / limits
AIU_TOP_K=5
AIU_MAX_RESULT_ROWS=5000
# Embedding dimension (must match the embedding model; nomic-embed-text = 768).
AIU_EMBEDDING_DIM=768
# Minimum cosine similarity for a retrieved doc chunk to count as relevant.
AIU_MIN_SIMILARITY=0.4

# --- NOP content (PocketBase) ---------------------------------------------
# EUROCONTROL Network Operations Portal message updates (collection nop_content).
PB_NOP_URL=https://aiu-nop.pockethost.io
PB_NOP_USER_EMAIL=
PB_NOP_USER_PASSWORD=

# --- Chat logging (PocketBase) --------------------------------------------
# Every conversation turn is logged for quality & analysis. The app authenticates
# as a dedicated, create-only "log user" (never the superuser). Leave the log-user
# creds blank to disable logging, or set AIU_CHAT_LOGGING=false.
PB_CHAT_URL=https://aiu-chat.pockethost.io
PB_CHAT_USER_EMAIL=
PB_CHAT_USER_PASSWORD=
AIU_CHAT_LOGGING=true
# Superuser creds — used ONLY by the hidden viewer to READ logs (the app never
# needs these). Omit them from the public deployment if you view logs elsewhere.
PB_ADMIN_USER_EMAIL=
PB_ADMIN_USER_PASSWORD=

# --- Admin viewer ----------------------------------------------------------
# The conversation viewer appears as a "Viewer" page in the nav and is gated by
# this password (separate from the main app password). Set it to enable the page;
# leave blank to hide the viewer entirely. (AIU_ADMIN_VIEW_SLUG is no longer
# required and can be left blank.)
AIU_ADMIN_VIEW_PASSWORD=
AIU_ADMIN_VIEW_SLUG=

# --- EUROCONTROL Data App API ---------------------------------------------
# Public read API; no credentials needed. Override only if the host changes.
AIU_DATAAPP_BASE=https://api-data-app.eurocontrol.int/api
