# Copy to .env and adjust as needed. All values have sensible defaults in config.py.

# Ollama
OLLAMA_HOST=http://localhost:11434
AIU_MODEL_NAME=qwen3.5:9b
AIU_EMBEDDING_MODEL=nomic-embed-text
# Context window cap (small prompts; avoids a 256K-context memory blowup).
AIU_OLLAMA_NUM_CTX=8192
# HTTP timeout in seconds (covers a cold model load on the first request).
AIU_OLLAMA_TIMEOUT=180
# Keep reasoning-model "thinking" off (much faster for SQL/JSON). Set true to enable.
AIU_OLLAMA_THINK=false

# Paths (defaults are relative to the repo root)
# AIU_DATA_DIR=./data
# AIU_PARQUET_DIR=./data/parquet
# AIU_DUCKDB_PATH=./data/aiu.duckdb
# AIU_CATALOG_PATH=./data/catalog.json

# Retrieval / limits
AIU_TOP_K=5
AIU_MAX_RESULT_ROWS=5000
# Embedding dimension (must match the embedding model; nomic-embed-text = 768).
AIU_EMBEDDING_DIM=768
# Minimum cosine similarity for a retrieved doc chunk to count as relevant.
AIU_MIN_SIMILARITY=0.4

# --- NOP content (PocketBase) ---------------------------------------------
# EUROCONTROL Network Operations Portal message updates (collection nop_content).
PB_NOP_URL=https://aiu-nop.pockethost.io
PB_NOP_USER_EMAIL=
PB_NOP_USER_PASSWORD=

# --- EUROCONTROL Data App API ---------------------------------------------
# Public read API; no credentials needed. Override only if the host changes.
AIU_DATAAPP_BASE=https://api-data-app.eurocontrol.int/api
