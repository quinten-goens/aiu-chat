# Streamlit Cloud secrets for the cloud (OpenAI) deployment.
# Copy these into your app's Settings → Secrets on share.streamlit.io.
# (Locally, use a .env file instead — see .env.example.)

LOCAL = "false"
OPENAI_KEY = "sk-..."           # your OpenAI API key (chat + embeddings)

# NOP live source (optional; needed for NOP questions)
PB_NOP_URL = "https://aiu-nop.pockethost.io"
PB_NOP_USER_EMAIL = "you@example.com"
PB_NOP_USER_PASSWORD = "..."

# Optional model overrides (defaults shown):
# AIU_OPENAI_NANO = "gpt-5.4-nano"
# AIU_OPENAI_MINI = "gpt-5.4-mini"
# AIU_OPENAI_MAX  = "gpt-5.5"
# AIU_MODEL_TIER  = "gpt_mini"
