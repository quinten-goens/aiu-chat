# Streamlit Cloud secrets for the cloud (OpenAI) deployment.
# Copy these into your app's Settings → Secrets on share.streamlit.io.
# (Locally, use a .env file instead — see .env.example.)

LOCAL = "false"
OPENAI_KEY = "sk-..."           # your OpenAI API key (chat + embeddings)

# NOP live source (optional; needed for NOP questions)
PB_NOP_URL = "https://aiu-nop.pockethost.io"
PB_NOP_USER_EMAIL = "you@example.com"
PB_NOP_USER_PASSWORD = "..."

# Chat logging (records every conversation). The app writes as a create-only log
# user; leave blank / set AIU_CHAT_LOGGING="false" to disable.
PB_CHAT_URL = "https://aiu-chat.pockethost.io"
PB_CHAT_USER_EMAIL = "..."
PB_CHAT_USER_PASSWORD = "..."
AIU_CHAT_LOGGING = "true"

# Conversation viewer — set this password to enable the "Viewer" nav page (gated
# by this password, separate from the main app login). Superuser creds are only
# needed here (the app itself never reads logs). Consider viewing logs from a
# private local run instead of shipping these to the cloud.
AIU_ADMIN_VIEW_PASSWORD = "..."
# PB_ADMIN_USER_EMAIL = "..."      # only if you enable the viewer on the cloud app
# PB_ADMIN_USER_PASSWORD = "..."

# Optional model overrides (defaults shown):
# AIU_OPENAI_NANO = "gpt-5.4-nano"
# AIU_OPENAI_MINI = "gpt-5.4-mini"
# AIU_OPENAI_MAX  = "gpt-5.5"
# AIU_MODEL_TIER  = "gpt_mini"
